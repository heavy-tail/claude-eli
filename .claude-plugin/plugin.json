{
  "name": "eli",
  "version": "1.0.0",
  "description": "Claude ELI. Translate Claude's technical explanations into plain language with analogies. Code blocks, commands, URLs, paths — preserved 100%.",
  "author": {
    "name": "WH",
    "url": "https://github.com/heavy-tail"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/eli-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading Claude ELI..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/eli-mode-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Tracking ELI mode..."
          }
        ]
      }
    ]
  }
}
